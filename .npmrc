# react-day-picker@8 declares a peer range of react ^16.8 || ^17 || ^18 and was never
# updated for React 19, which this project uses. v8 works fine at runtime under 19 —
# only the peer metadata is stale — so relax npm's strict peer resolution.
# Remove this once react-day-picker is upgraded to v9 (requires rewriting
# components/ui/calendar.tsx for the v9 classNames/components API).
legacy-peer-deps=true
